# =============================================================================
# NEURON — Environment Configuration
# Copy to .env.local (dashboard) or .env (MCP server)
# =============================================================================

# --- Cloud Supabase (production) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon key (fallback if publishable key not set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Local Supabase (development) ---
# Run: supabase start && supabase status
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (from supabase status)

# Which backend to use: cloud | local
NEURON_SUPABASE_MODE=cloud

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI (server-only on Vercel — never give to MCP customers) ---
GROQ_API_KEY=gsk_...
# Embeddings: local (default, in-process) | off | huggingface
NEURON_EMBEDDINGS=local
# MCP response format default: brief | compact | full
NEURON_MCP_FORMAT=brief
# Only if NEURON_EMBEDDINGS=huggingface
# HUGGINGFACE_API_KEY=hf_...

# --- MCP customers (hosted mode) ---
# Get from dashboard → MCP Setup → Generate key, then:
# npx @anuraghq/neuron-mcp-server init --api-key nrn_...
# Or: npx @anuraghq/neuron-mcp-server init  (interactive prompt)

# --- MCP local dev (direct mode — optional) ---
# NEURON_PROJECT_ID=your-project-uuid
