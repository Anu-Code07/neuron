# =============================================================================
# NEURON — Environment Configuration
# Copy to .env.local (dashboard) or .env (MCP server)
# =============================================================================

# --- Cloud Supabase (production) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon key (fallback if publishable key not set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Local Supabase (development) ---
# Run: supabase start && supabase status
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (from supabase status)

# Which backend to use: cloud | local
NEURON_SUPABASE_MODE=cloud

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI (server-only on Vercel — never give to MCP customers) ---
GROQ_API_KEY=gsk_...

# --- MCP customers (hosted mode) ---
# Get from dashboard → Settings → Generate demo API key
# NEURON_API_KEY=nrn_...
# NEURON_API_URL=https://neuron-azure.vercel.app

# --- MCP local dev (direct mode — optional) ---
# NEURON_PROJECT_ID=your-project-uuid
