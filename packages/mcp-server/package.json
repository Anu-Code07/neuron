{
  "name": "@neuron/mcp-server",
  "version": "0.1.2",
  "description": "Neuron Context Engine — MCP server for Cursor, Claude, and any MCP client",
  "type": "module",
  "bin": {
    "neuron-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/index.js", "dist/index.js.map", "README.md"],
  "keywords": ["mcp", "neuron", "context-engine", "cursor", "claude", "ai-memory"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anu-Code07/neuron",
    "directory": "packages/mcp-server"
  },
  "scripts": {
    "build": "tsc",
    "build:publish": "node scripts/bundle.mjs && node scripts/prepare-publish.mjs",
    "publish:npm": "NPM_PUBLISH_NAME=@anuraghq/neuron-mcp-server pnpm run build:publish && npm publish .publish --access public",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build:publish",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@neuron/context-engine": "workspace:*",
    "@neuron/shared": "workspace:*",
    "@neuron/supabase": "workspace:*",
    "dotenv": "^16.5.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
